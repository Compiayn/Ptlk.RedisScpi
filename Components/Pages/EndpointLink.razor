            TcpHost = "127.0.0.1",
            TcpPort = 5025,
            TimeoutMs = ScpiSettings.Value.DefaultTimeoutMs,
            PollingIntervalMs = ScpiSettings.Value.DefaultPollingIntervalMs,
            ConverterId = RedisScpiSettings.Value.ConverterId,
            ErrorCheckMode = ScpiSettings.Value.DefaultErrorCheckMode,
            ErrorQueueQuery = ScpiSettings.Value.DefaultErrorQueueQuery,
            CommandTerminator = ScpiSettings.Value.DefaultCommandTerminator,
            ResponseTerminator = ScpiSettings.Value.DefaultResponseTerminator,
            Enabled = true
        };

    private static ScpiPointConfig NewPoint(int endpointId) =>
        new()
        {
            EndpointConfigId = endpointId,
            Enabled = false,
            PollingEnabled = false,
            InitialRead = true,
            Access = ScpiAccessModes.Readonly,
            DataType = ScpiDataTypes.String,
            NumberType = ScpiNumberTypes.Double,
            StringFormat = ScpiStringFormats.Raw,
            EnumFormat = ScpiEnumFormats.Value,
