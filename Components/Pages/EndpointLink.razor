    private static string EscapeTerminator(string value) =>
        value
            .Replace("\\", "\\\\", StringComparison.Ordinal)
            .Replace("\r", "\\r", StringComparison.Ordinal)
            .Replace("\n", "\\n", StringComparison.Ordinal)
            .Replace("\t", "\\t", StringComparison.Ordinal);

    private static string UnescapeTerminator(string value)
    {
        var builder = new System.Text.StringBuilder(value.Length);
        for (var index = 0; index < value.Length; index++)
        {
            var current = value[index];
            if (current != '\\')
            {
                builder.Append(current);
                continue;
            }
            if (++index >= value.Length)
            {
                throw new InvalidOperationException("A terminator escape sequence is incomplete.");
            }

            builder.Append(value[index] switch
            {
                'n' => '\n',
                'r' => '\r',
                't' => '\t',
                '\\' => '\\',
                _ => throw new InvalidOperationException($"Unsupported terminator escape sequence '\\{value[index]}'.")
            });
        }

        if (builder.Length == 0)
        {
            throw new InvalidOperationException("A terminator is required.");
        }
        return builder.ToString();
    }

