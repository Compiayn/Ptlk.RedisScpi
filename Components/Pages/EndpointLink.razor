        };

    private static ScpiEndpointConfig CloneEndpoint(ScpiEndpointConfig source) =>
        new()
        {
            Id = source.Id,
            EndpointId = source.EndpointId,
            DisplayName = source.DisplayName,
            Enabled = source.Enabled,
            Transport = source.Transport,
            TcpHost = source.TcpHost,
            TcpPort = source.TcpPort,
            TimeoutMs = source.TimeoutMs,
            PollingIntervalMs = source.PollingIntervalMs,
            ConverterId = source.ConverterId,
            ErrorCheckMode = source.ErrorCheckMode,
            ErrorQueueQuery = source.ErrorQueueQuery,
            CommandTerminator = source.CommandTerminator,
            ResponseTerminator = source.ResponseTerminator,
            CreatedAt = source.CreatedAt,
            UpdatedAt = source.UpdatedAt,
            ConcurrencyStamp = source.ConcurrencyStamp
        };

    private static ScpiPointConfig ClonePoint(ScpiPointConfig source) =>
        new()
        {
            Id = source.Id,
            EndpointConfigId = source.EndpointConfigId,
            PointId = source.PointId,
            SourcePath = source.SourcePath,
            Name = source.Name,
            DisplayName = source.DisplayName,
            Enabled = source.Enabled,
            Access = source.Access,
            DataType = source.DataType,
            NumberType = source.NumberType,
            StringFormat = source.StringFormat,
            EnumFormat = source.EnumFormat,
            ReadTemplate = source.ReadTemplate,
            WriteTemplate = source.WriteTemplate,
            Unit = source.Unit,
            PollingEnabled = source.PollingEnabled,
            PollingIntervalMs = source.PollingIntervalMs,
            InitialRead = source.InitialRead,
            CreatedAt = source.CreatedAt,
            UpdatedAt = source.UpdatedAt,
            ConcurrencyStamp = source.ConcurrencyStamp,
            EnumOptions = source.EnumOptions
                .OrderBy(option => option.SortOrder)
                .ThenBy(option => option.Id)
                .Select(CloneEnumOption)
                .ToList()
        };

    private static ScpiEnumOption CloneEnumOption(ScpiEnumOption source) =>
        new()
        {
            Id = source.Id,
            ScpiPointConfigId = source.ScpiPointConfigId,
            DisplayName = source.DisplayName,
            Value = source.Value,
            Code = source.Code,
            SortOrder = source.SortOrder,
            CreatedAt = source.CreatedAt,
            UpdatedAt = source.UpdatedAt
        };

