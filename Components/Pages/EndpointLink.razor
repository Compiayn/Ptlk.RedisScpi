        catch (ScpiConfigurationConcurrencyException ex)
        {
            ClearDelete();
            await LoadAsync();
            await ScreenAlerts.ShowAsync(ex.Message, ScreenAlertSeverity.Warning, "Stale endpoint delete");
        }
        catch (Exception ex)
