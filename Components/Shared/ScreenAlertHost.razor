@implements IDisposable
@inject ScreenAlertService ScreenAlerts

@if (current is not null)
{
    <div class="screen-alert-region" aria-live="@AriaLive(current)" aria-atomic="true">
        <div @key="current.Id" class="@AlertClass(current, leaving)" role="@AlertRole(current)"
             @onmouseenter="Pause" @onmouseleave="Resume">
            <div class="screen-alert-content">
                <div class="screen-alert-title">@(current.Title ?? DefaultTitle(current.Severity))</div>
                <div class="screen-alert-message">@current.Message</div>
            </div>
            <button class="screen-alert-close" type="button" aria-label="Dismiss alert" @onclick="CompleteAsync">x</button>
        </div>
    </div>
}

@code {
    private static readonly TimeSpan ExitDuration = TimeSpan.FromMilliseconds(180);
    private readonly Queue<ScreenAlertMessage> queue = new();
    private ScreenAlertMessage? current;
    private CancellationTokenSource? timer;
    private DateTimeOffset dismissAt;
    private TimeSpan remaining;
    private bool paused;
    private bool leaving;
    private bool disposed;

    protected override void OnInitialized()
    {
        ScreenAlerts.AlertsChanged += OnChanged;
        Drain();
    }

    private void OnChanged()
    {
        if (!disposed)
        {
            _ = InvokeAsync(Drain);
        }
    }

    private void Drain()
    {
        foreach (var message in ScreenAlerts.Drain())
        {
            queue.Enqueue(message);
        }

        if (current is null)
        {
            ShowNext();
        }
        else
        {
            StateHasChanged();
        }
    }

    private void ShowNext()
    {
        CancelTimer();
        current = queue.TryDequeue(out var next) ? next : null;
        paused = false;
        leaving = false;
        if (current is not null)
        {
            StartTimer(current.Duration);
        }
        StateHasChanged();
    }

    private void StartTimer(TimeSpan delay)
    {
        CancelTimer();
        timer = new CancellationTokenSource();
        dismissAt = DateTimeOffset.UtcNow.Add(delay);
        _ = RunTimerAsync(current!.Id, delay, timer.Token);
    }

    private async Task RunTimerAsync(Guid id, TimeSpan delay, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(delay, cancellationToken);
            await InvokeAsync(async () =>
            {
                if (!paused && current?.Id == id)
                {
                    await CompleteAsync();
                }
            });
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private void Pause()
    {
        if (current is null || paused || leaving)
        {
            return;
        }
        paused = true;
        remaining = dismissAt - DateTimeOffset.UtcNow;
        CancelTimer();
    }

    private void Resume()
    {
        if (current is null || !paused || leaving)
        {
            return;
        }
        paused = false;
        if (remaining <= TimeSpan.Zero)
        {
            _ = CompleteAsync();
        }
        else
        {
            StartTimer(remaining);
        }
    }

    private async Task CompleteAsync()
    {
        CancelTimer();
        paused = false;
        if (current is null)
        {
            return;
        }
        if (queue.Count > 0)
        {
            ShowNext();
            return;
        }
        leaving = true;
        StateHasChanged();
        await Task.Delay(ExitDuration);
        if (!disposed)
        {
            current = null;
            leaving = false;
            StateHasChanged();
        }
    }

    private void CancelTimer()
    {
        timer?.Cancel();
        timer?.Dispose();
        timer = null;
    }

    public void Dispose()
    {
        disposed = true;
        ScreenAlerts.AlertsChanged -= OnChanged;
        CancelTimer();
    }

    private static string AlertClass(ScreenAlertMessage alert, bool isLeaving) =>
        $"screen-alert screen-alert-{alert.Severity.ToString().ToLowerInvariant()}{(isLeaving ? " leaving" : "")}";

    private static string DefaultTitle(ScreenAlertSeverity severity) => severity switch
    {
        ScreenAlertSeverity.Success => "Completed",
        ScreenAlertSeverity.Warning => "Warning",
        ScreenAlertSeverity.Error => "Error",
        _ => "Notice"
    };

    private static string AlertRole(ScreenAlertMessage alert) =>
        alert.Severity is ScreenAlertSeverity.Error or ScreenAlertSeverity.Warning ? "alert" : "status";

    private static string AriaLive(ScreenAlertMessage alert) =>
        alert.Severity is ScreenAlertSeverity.Error or ScreenAlertSeverity.Warning ? "assertive" : "polite";
}
